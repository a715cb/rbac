# =========================
# 应用配置
# =========================
APP_DEBUG=false

# =========================
# 数据库配置
# =========================
DB_CONNECTION=mysql
DB_HOSTNAME=127.0.0.1
DB_PORT=3306
DB_DATABASE=rbac_system
DB_USERNAME=root
DB_PASSWORD=your_secure_password
DB_CHARSET=utf8mb4

# =========================
# JWT 配置（重要安全设置）
# =========================
# 警告：JWT_SECRET 必须设置，不允许使用默认值！
# 生成强密钥方法（选择其一）：
# 1. 快速配置：php setup_jwt_secret.php
# 2. PHP: php -r "echo bin2hex(random_bytes(32));"
# 3. PHP: php -r "echo base64_encode(openssl_random_pseudo_bytes(32));"
# 4. OpenSSL: openssl rand -base64 32
# 密钥长度要求：至少 32 字符，推荐使用 64 字符
# 密钥必须包含：大小写字母和数字
JWT_SECRET=your_64_character_strong_random_secret_key_here_change_in_production
JWT_TTL=1440
JWT_REFRESH_TTL=10080

# =========================
# Redis 配置
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =========================
# 缓存配置
# =========================
CACHE_DRIVER=file

# =========================
# 日志配置
# =========================
LOG_LEVEL=error

# =========================
# Knowledge Graph Memory 配置
# =========================
# 知识图谱内存数据文件的存储路径
# 可以是相对路径（相对于后端项目根目录）或绝对路径
# 确保应用程序对该路径具有读写权限
MEMORY_FILE_PATH=runtime/data/knowledge_graph_memory.json

# =========================
# 微信小程序配置
# =========================
WX_MINIAPP_APPID=
WX_MINIAPP_SECRET=
