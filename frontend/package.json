    "ant-design-vue": "^4.1.0",
    "axios": "^1.6.5",
    "dayjs": "^1.11.10",
    "highlight.js": "^11.11.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "sortablejs": "^1.15.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
